# Database
DATABASE_URL=postgresql://postgres:postgres@pgbouncer:6432/mcp_bridge

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Groq
GROQ_MODEL=llama-3.3-70b-versatile

# Server
BACKEND_PORT=8000
ENVIRONMENT=development                    # "development" or "production"
ALLOWED_ORIGINS=https://localhost,http://localhost:5173,http://localhost:3000

# Redis
REDIS_URL=redis://redis:6379

# Approvals
APPROVAL_TIMEOUT_MINUTES=10

# Observability (optional)
# SENTRY_DSN=https://key@sentry.io/project
# SENTRY_TRACES_SAMPLE_RATE=0.1
# OTEL_ENDPOINT=http://otel-collector:4318
# AUDIT_LOG_RETENTION_DAYS=90

# Notifications (optional)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# SSO/OIDC (optional — uncomment and fill in to enable)
# SSO_ISSUER_URL=https://your-tenant.auth0.com/
# SSO_CLIENT_ID=your-client-id
# SSO_CLIENT_SECRET=your-client-secret
# SSO_PROVIDER=auth0
# SSO_SCOPE=openid email profile
# FRONTEND_URL=https://localhost
